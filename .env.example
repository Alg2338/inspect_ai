# Copy this file to `.env` and fill in the key for the ONE route you picked
# in the "How to pick a provider" table (first tutorial notebook).
# Inspect AI loads `.env` automatically, so keys never go into the cells.
# `.env` is gitignored; this example file is safe to commit.
# The entries below cover common routes, but any other inspect_ai provider works too,
# each with its own variable names listed at https://inspect.aisi.org.uk/providers.html.

# Local Ollama needs no key. If that's your route, leave this file as is.

# OpenRouter - https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# OpenAI (a real OpenAI key) - https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Any other OpenAI-compatible vendor (DeepSeek, Groq, a local vLLM server, ...).
# Pick a label for <service>, use it in MODEL as openai-api/<service>/<model>,
# then set the two matching vars. Example for DeepSeek (openai-api/deepseek/deepseek-chat):
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Perplexity - https://www.perplexity.ai/settings/api
# PERPLEXITY_API_KEY=
